{
	"name": "web",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "npm run wasm && vite dev",
		"build": "npm run wasm && vite build",
		"wasm": "wasm-pack build ../wasm",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
