		"svelte": "^4.2.8",
		"svelte-check": "^3.6.3",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3",
		"vite": "^5.0.11",
		"vite-plugin-top-level-await": "^1.4.1",
		"vite-plugin-wasm": "^3.3.0",
		"wasm-pack": "^0.12.1"
	},
	"type": "module"
}
