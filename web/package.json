		"cpc": "file:../pkg",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.1.8",
		"typescript": "^6.0.3",
		"vercel": "^54.14.2",
		"vite": "^7.3.5",
		"vite-plugin-wasm": "^3.6.0",
		"wasm-pack": "^0.15.0"
	}
