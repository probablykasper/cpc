{
	"private": true,
	"type": "module",
	"scripts": {
		"build-wasm": "npx wasm-pack build --target bundler",
		"dev": "npm run build-wasm && vite dev",
		"build": "npm run build-wasm && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
